<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Browse Machines — GymForge</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
  <link rel="stylesheet" href="../css/style.css"/>
</head>
<body>

  <div id="gf-navbar"></div>

  <!-- Page Hero -->
  <div class="page-hero">
    <div class="container">
      <span class="section-label">Equipment Catalog</span>
      <h1 class="section-title">BROWSE <span class="text-primary-gf">MACHINES</span></h1>
      <p class="text-muted-gf" style="font-size:0.95rem;">Commercial-grade gym equipment. Filter by category and find the perfect machine for your facility.</p>
    </div>
  </div>

  <div class="page-wrapper">
    <div class="container">

      <!-- Filter + Count Row -->
      <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-3">
        <div class="filter-chips" id="category-chips">
          <button class="chip active" data-cat="All">All</button>
          <button class="chip" data-cat="Cardio">Cardio</button>
          <button class="chip" data-cat="Strength">Strength</button>
          <button class="chip" data-cat="Functional">Functional</button>
          <button class="chip" data-cat="Free Weights">Free Weights</button>
          <button class="chip" data-cat="Recovery">Recovery</button>
        </div>
        <div class="fw-condensed text-muted-gf" style="font-size:0.85rem;letter-spacing:1px;">
          SHOWING <span id="result-count" style="color:var(--primary);">0</span> MACHINES
        </div>
      </div>

      <!-- Sort Row -->
      <div class="d-flex gap-2 align-items-center mb-4 flex-wrap">
        <label class="gf-label mb-0" style="white-space:nowrap;">Sort by:</label>
        <select id="sort-select" class="gf-input" style="width:auto;min-width:160px;">
          <option value="default">Default</option>
          <option value="price-asc">Price: Low to High</option>
          <option value="price-desc">Price: High to Low</option>
          <option value="name-az">Name: A–Z</option>
          <option value="rating">Top Rated</option>
        </select>
      </div>

      <!-- Machines Grid -->
      <div class="row g-4" id="machines-grid">
        <!-- Rendered by JS -->
      </div>

      <!-- No Results -->
      <div id="no-results" style="display:none;text-align:center;padding:3rem 0;">
        <div style="font-size:3rem;margin-bottom:1rem;"><i class="fa-solid fa-magnifying-glass" style="color:var(--text-muted);"></i></div>
        <h4 class="fw-condensed" style="letter-spacing:1px;color:var(--text-muted);">NO MACHINES FOUND</h4>
        <p class="text-muted-gf">Try a different category or check back later.</p>
      </div>

    </div>
  </div>

  <div id="gf-footer"></div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="../js/api.js"></script>
  <script src="../js/main.js"></script>
  <script>
    $(document).ready(async function () {
      const mRes = await API.getMachines();
      const machinesList = mRes.success ? mRes.machines : [];
      const user = await GF.loadUser();
      GF.renderNavbar('machines');
      GF.renderFooter();

      let currentCat = 'All';
      let currentSort = 'default';

      function getMachines() {
        let list = [...machinesList];
        if (currentCat !== 'All') list = list.filter(m => m.category === currentCat);
        switch (currentSort) {
          case 'price-asc':  list.sort((a, b) => a.price - b.price); break;
          case 'price-desc': list.sort((a, b) => b.price - a.price); break;
          case 'name-az':    list.sort((a, b) => a.name.localeCompare(b.name)); break;
          case 'rating':     list.sort((a, b) => b.rating - a.rating); break;
        }
        return list;
      }

      function renderMachines() {
        const list = getMachines();
        const $grid = $('#machines-grid').empty();
        $('#no-results').hide();

        if (list.length === 0) { $('#no-results').show(); $('#result-count').text(0); return; }
        $('#result-count').text(list.length);

        list.forEach((m, i) => {
          const statusClass = m.status === 'Available' ? 'gf-badge-success' : m.status === 'Low Stock' ? 'gf-badge-warning' : 'gf-badge-danger';
          const stars = '★'.repeat(Math.floor(m.rating)) + (m.rating % 1 >= 0.5 ? '½' : '');

          $grid.append(`
            <div class="col-sm-6 col-lg-4 machine-card" style="animation: fadeUp 0.3s ease ${i * 0.05}s both;">
              <div class="gf-card h-100">
                <div class="gf-card-img-placeholder" style="cursor:pointer;overflow:hidden;" onclick="window.location.href='machine-detail.html?id=${m.id}'">
                  ${m.image ? `<img src="../${m.image}" alt="${m.name}" style="width:100%;height:100%;object-fit:cover;">` : `<div style="font-size:3rem;display:flex;align-items:center;justify-content:center;height:100%;"><i class="fa-solid ${m.icon}"></i></div>`}
                </div>
                <div class="gf-card-body d-flex flex-column">
                  <div class="d-flex justify-content-between mb-2">
                    <span class="gf-badge gf-badge-muted">${m.category}</span>
                    <span class="gf-badge ${statusClass}">${m.status}</span>
                  </div>
                  <h5 style="font-family:var(--font-condensed);font-weight:700;font-size:1.05rem;letter-spacing:0.5px;margin-bottom:0.4rem;">${m.name}</h5>
                  <div style="font-size:0.8rem;color:var(--text-muted);margin-bottom:0.3rem;">
                    <span style="color:#f59e0b;">${stars}</span>
                    <span style="margin-left:4px;">${m.rating} (${m.reviews} reviews)</span>
                  </div>
                  <p style="color:var(--text-muted);font-size:0.85rem;margin-bottom:1rem;flex:1;">${m.description.substring(0, 95)}…</p>
                  <div class="d-flex justify-content-between align-items-center mt-auto">
                    <span class="price-tag" style="font-size:1.4rem;"><span class="currency" style="font-size:0.9rem;">OMR </span>${m.price.toFixed(2)}</span>
                    <a href="machine-detail.html?id=${m.id}" class="btn-primary-gf" style="font-size:0.82rem;padding:0.45rem 1rem;">View Details</a>
                  </div>
                </div>
              </div>
            </div>`);
        });
      }

      /* Category filter chips */
      $('#category-chips').on('click', '.chip', function () {
        $('.chip').removeClass('active');
        $(this).addClass('active');
        currentCat = $(this).data('cat');
        renderMachines();
      });

      /* Sort */
      $('#sort-select').on('change', function () {
        currentSort = $(this).val();
        renderMachines();
      });

      renderMachines();
    });
  </script>
  <style>
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</body>
</html>
